{
  "name": "@pensyve/sdk",
  "version": "1.1.0",
  "description": "Pensyve TypeScript SDK — universal memory runtime for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/major7apps/pensyve.git",
    "directory": "pensyve-ts"
  },
  "homepage": "https://pensyve.com",
  "bugs": "https://github.com/major7apps/pensyve/issues",
  "keywords": [
    "ai",
    "agents",
    "memory",
    "llm",
    "mcp",
    "retrieval",
    "embeddings"
  ],
  "scripts": {
    "build": "bun run tsc",
    "lint": "bun run eslint src/",
    "lint:fix": "bun run eslint src/ --fix",
    "test": "bun test",
    "check": "bun run lint && bun run build && bun test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  },
  "license": "Apache-2.0",
  "author": "Major7 Apps",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
