{
  "name": "pensyve",
  "displayName": "Pensyve",
  "description": "Universal memory runtime for AI agents — recall, remember, and inspect memories from VS Code",
  "version": "1.1.0",
  "publisher": "major7apps",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/major7apps/pensyve",
    "directory": "integrations/vscode"
  },
  "homepage": "https://pensyve.com",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Data Science"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pensyve.recall",
        "title": "Pensyve: Recall Memories"
      },
      {
        "command": "pensyve.remember",
        "title": "Pensyve: Remember Fact"
      },
      {
        "command": "pensyve.stats",
        "title": "Pensyve: Memory Stats"
      },
      {
        "command": "pensyve.consolidate",
        "title": "Pensyve: Consolidate Memories"
      }
    ],
    "configuration": {
      "title": "Pensyve",
      "properties": {
        "pensyve.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Pensyve REST API server URL"
        },
        "pensyve.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticated requests"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pensyve",
          "title": "Pensyve",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "pensyve": [
        {
          "type": "webview",
          "id": "pensyve.sidebar",
          "name": "Memory Browser"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
