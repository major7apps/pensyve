---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Documentation - Pensyve" description="Getting started with Pensyve, the universal memory runtime for AI agents.">
  <!-- Navigation -->
  <nav class="fixed top-0 z-50 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-lg">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2 text-xl font-bold">
        <img src="/favicon.svg" alt="Pensyve" class="h-7 w-7" />
        <span class="gradient-text">pensyve</span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="/" class="text-sm text-[var(--color-text-secondary)] transition-colors hover:text-white">Home</a>
        <a href="/docs" class="text-sm text-white">Docs</a>
        <a href="https://github.com/major7apps/pensyve" class="btn-secondary text-sm" target="_blank" rel="noopener">
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <main class="pt-32 pb-24">
    <div class="mx-auto max-w-4xl px-6">
      <h1 class="text-4xl font-bold">
        <span class="gradient-text">Documentation</span>
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)]">
        Everything you need to integrate pensyve into your AI agent.
      </p>

      <div class="mt-16 space-y-16">
        <!-- Installation -->
        <section>
          <h2 class="text-2xl font-bold">Installation</h2>
          <div class="mt-6 space-y-6">
            <div>
              <h3 class="mb-3 text-lg font-semibold">Python</h3>
              <div class="code-block">
                <pre><code>pip install pensyve</code></pre>
              </div>
            </div>
            <div>
              <h3 class="mb-3 text-lg font-semibold">From source (Rust + Python)</h3>
              <div class="code-block">
                <pre><code>git clone https://github.com/major7apps/pensyve.git
cd pensyve
make build</code></pre>
              </div>
            </div>
            <div>
              <h3 class="mb-3 text-lg font-semibold">TypeScript</h3>
              <div class="code-block">
                <pre><code>npm install pensyve
<span class="text-[var(--color-text-secondary)]"># or</span>
bun add pensyve</code></pre>
              </div>
            </div>
          </div>
        </section>

        <!-- Core Concepts -->
        <section>
          <h2 class="text-2xl font-bold">Core Concepts</h2>
          <div class="mt-6 space-y-6">
            <div class="card">
              <h3 class="text-lg font-semibold">Namespaces</h3>
              <p class="mt-2 text-[var(--color-text-secondary)]">
                Top-level isolation boundary. Each agent or application gets its own namespace with independent storage.
              </p>
            </div>
            <div class="card">
              <h3 class="text-lg font-semibold">Entities</h3>
              <p class="mt-2 text-[var(--color-text-secondary)]">
                Represent agents, users, teams, or tools. Each entity has its own memory scope within a namespace.
              </p>
            </div>
            <div class="card">
              <h3 class="text-lg font-semibold">Episodes</h3>
              <p class="mt-2 text-[var(--color-text-secondary)]">
                Bounded interaction sequences containing messages. Episodes are the unit of experience -- memories are extracted from them.
              </p>
            </div>
            <div class="card">
              <h3 class="text-lg font-semibold">Memories</h3>
              <p class="mt-2 text-[var(--color-text-secondary)]">
                Three types: <strong>episodic</strong> (event records), <strong>semantic</strong> (SPO knowledge triples), and <strong>procedural</strong> (action-outcome pairs with reliability scores).
              </p>
            </div>
          </div>
        </section>

        <!-- Memory Types -->
        <section>
          <h2 class="text-2xl font-bold">Memory Types</h2>
          <div class="mt-6 overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-[var(--color-border)]">
                  <th class="pb-3 pr-8 font-semibold">Type</th>
                  <th class="pb-3 pr-8 font-semibold">Structure</th>
                  <th class="pb-3 font-semibold">Use Case</th>
                </tr>
              </thead>
              <tbody class="text-[var(--color-text-secondary)]">
                <tr class="border-b border-[var(--color-border)]/50">
                  <td class="py-3 pr-8 text-[var(--color-text)]">Episodic</td>
                  <td class="py-3 pr-8">Free-form text</td>
                  <td class="py-3">"User asked about deployment on March 5th"</td>
                </tr>
                <tr class="border-b border-[var(--color-border)]/50">
                  <td class="py-3 pr-8 text-[var(--color-text)]">Semantic</td>
                  <td class="py-3 pr-8">Subject-Predicate-Object</td>
                  <td class="py-3">"User prefers dark-mode"</td>
                </tr>
                <tr>
                  <td class="py-3 pr-8 text-[var(--color-text)]">Procedural</td>
                  <td class="py-3 pr-8">Action-Outcome + reliability</td>
                  <td class="py-3">"Deploy via CI has 95% success rate"</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Retrieval -->
        <section>
          <h2 class="text-2xl font-bold">Multi-Signal Retrieval</h2>
          <p class="mt-4 text-[var(--color-text-secondary)]">
            Pensyve's recall engine fuses eight signals into a single relevance score:
          </p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">vector</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Cosine similarity via ONNX embeddings</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">bm25</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Full-text search via SQLite FTS5</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">graph</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Entity relationship proximity</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">recency</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Exponential time decay</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">frequency</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Access count normalization</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">confidence</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Source reliability weighting</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">type_boost</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Memory type preference</span>
            </div>
            <div class="card py-4">
              <span class="text-brand-400 font-mono text-sm">reranker</span>
              <span class="ml-2 text-sm text-[var(--color-text-secondary)]">Cross-encoder refinement</span>
            </div>
          </div>
        </section>

        <!-- Links -->
        <section>
          <h2 class="text-2xl font-bold">Resources</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2">
            <a href="https://github.com/major7apps/pensyve" class="card transition-colors hover:border-brand-600/50" target="_blank" rel="noopener">
              <h3 class="font-semibold">GitHub Repository</h3>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)]">Source code, issues, and contributions</p>
            </a>
            <a href="https://github.com/major7apps/pensyve/blob/main/README.md" class="card transition-colors hover:border-brand-600/50" target="_blank" rel="noopener">
              <h3 class="font-semibold">API Reference</h3>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)]">Complete API documentation</p>
            </a>
            <a href="https://github.com/major7apps/pensyve/blob/main/docs/architecture.md" class="card transition-colors hover:border-brand-600/50" target="_blank" rel="noopener">
              <h3 class="font-semibold">Architecture Guide</h3>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)]">Deep dive into the engine internals</p>
            </a>
            <a href="https://github.com/major7apps/pensyve/blob/main/docs/getting-started.md" class="card transition-colors hover:border-brand-600/50" target="_blank" rel="noopener">
              <h3 class="font-semibold">Getting Started</h3>
              <p class="mt-1 text-sm text-[var(--color-text-secondary)]">Step-by-step setup guide</p>
            </a>
          </div>
        </section>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[var(--color-border)] py-12">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <div class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
          <img src="/favicon.svg" alt="Pensyve" class="h-5 w-5" />
          <span>pensyve</span>
          <span>&middot;</span>
          <span>Open source under MIT</span>
        </div>
        <div class="flex items-center gap-6 text-sm text-[var(--color-text-secondary)]">
          <a href="https://github.com/major7apps/pensyve" class="transition-colors hover:text-white" target="_blank" rel="noopener">GitHub</a>
          <a href="/docs" class="transition-colors hover:text-white">Docs</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
